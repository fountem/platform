{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@fountem/db": [
        "../../packages/db/src/index.ts"
      ],
      "@fountem/detection": [
        "../../packages/detection/src/index.ts"
      ],
      "@fountem/rag": [
        "../../packages/rag/src/index.ts"
      ],
      "@fountem/verdict": [
        "../../packages/verdict/src/index.ts"
      ]
    },
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
