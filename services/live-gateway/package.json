{
  "name": "@fountem/live-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Live fact-checking gateway: pulls a live stream's audio, runs streaming ASR (Deepgram), extracts check-worthy claims, and delegates verification to the Unfaked app. Deployed to AWS, talks to Supabase.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.2",
    "express": "^4.21.2",
    "openai": "^4.78.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
