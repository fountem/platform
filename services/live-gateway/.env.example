# Live gateway configuration
PORT=8090

# Must match the Unfaked app's LIVE_SESSION_SIGNING_KEY (HMAC token verification)
LIVE_SESSION_SIGNING_KEY=

# Supabase (service role) for writing transcript + claim rows
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Streaming ASR
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# Claim extraction
OPENAI_API_KEY=

# Unfaked app — gateway delegates verification to /api/live/verify-claim
UNFAKED_APP_URL=https://unfaked.ai
LIVE_INTERNAL_KEY=

# Per-session safety caps
LIVE_MAX_SESSION_MINUTES=90
LIVE_MAX_SESSION_CLAIMS=200
LIVE_MAX_CLAIMS_PER_MINUTE=12

# Election-period guardrail
LIVE_ELECTION_MODE=0
