# ─── Local / offline mock mode ──────────────────────────────
# Set both to 1 to run the WHOLE platform locally with NO external services
# (no AWS resolver, no Hive/Sensity, no OpenAI/Anthropic, no Supabase).
# /api/detect and /api/verify return deterministic, input-varied verdicts.
# Shortcut: `npm run dev:mock`. Leave unset/0 for real services.
MOCK_SERVICES=0
NEXT_PUBLIC_MOCK_SERVICES=0

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LLM ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # Claude Sonnet — RAG verdicts + claim decomposition
OPENAI_API_KEY=             # text-embedding-3-small + GPT-4o-mini contextual layer

# ─── Detection APIs ─────────────────────────────────────────
HIVE_API_KEY=               # Hive Moderation API
SENSITY_API_KEY=            # Sensity AI forensic video analysis

# ─── Media resolver (AWS service) ───────────────────────────
RESOLVER_URL=               # Internal ALB URL from `terraform output resolver_url`
RESOLVER_API_KEY=           # Shared secret; matches the resolver service. openssl rand -hex 32

# ─── Rate limiting ──────────────────────────────────────────
VALKEY_URL=                 # rediss://... from `terraform output valkey_url`. Falls back to in-memory if unset.

# ─── Auth & anti-abuse (Supabase Auth + quotas) ─────────────
# Auth uses NEXT_PUBLIC_SUPABASE_URL / _ANON_KEY above. Enable Email (magic link)
# and Google providers in the Supabase dashboard; add /auth/callback as a redirect URL.
TURNSTILE_SECRET_KEY=                  # Cloudflare Turnstile secret (server). Unset = captcha skipped (dev)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=        # Cloudflare Turnstile site key (client). Unset = widget hidden
UNFAKED_FREE_DAILY_LIMIT=5             # Per-account daily video checks (free tier)
FOUNTEM_FREE_DAILY_LIMIT=10            # Per-account daily claim checks (free tier)
UNFAKED_GLOBAL_DAILY_CAP=2000          # Global daily hard ceiling — circuit-breaker
FOUNTEM_GLOBAL_DAILY_CAP=4000          # Global daily hard ceiling — circuit-breaker

# ─── Admin / review ─────────────────────────────────────────
ADMIN_TOKEN=                # Protects /api/admin/review (human-review queue). openssl rand -hex 32

# ─── Observability (optional) ───────────────────────────────
SENTRY_DSN=                 # If set, captureException() forwards errors to Sentry. Logs to stdout otherwise.

# ─── X Bot ──────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_BOT_USER_ID=              # Numeric X user id the bot watches for mentions
UNFAKED_API_URL=https://unfaked.ai   # Bot calls {URL}/api/detect
UNFAKED_API_KEY=            # B2B API key so bot calls use the monthly quota, not per-IP limit
BOT_PUBLIC_URL=https://bot.unfaked.ai  # Bot's deployed base URL; the GitHub Actions cron hits {URL}/api/cron
CRON_SECRET=                # Authenticates the scheduled cron trigger (set as a GitHub secret too)
BOT_MAX_MENTIONS_PER_RUN=3  # Mentions handled per cron run (caps runtime; backlog drains over runs)

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://fountem.ai
