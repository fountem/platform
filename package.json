{
  "name": "fountem-platform",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "jest --passWithNoTests",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@supabase/supabase-js": "^2.47.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "jest": "^29.7.0",
    "openai": "^4.78.1",
    "ts-jest": "^29.2.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "ws": "^8.18.0"
  },
  "engines": { "node": ">=20.0.0" },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/packages/**/__tests__/**/*.test.ts",
      "**/apps/bot/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@fountem/db$": "<rootDir>/packages/db/src/index.ts",
      "^@fountem/verdict$": "<rootDir>/packages/verdict/src/index.ts",
      "^@fountem/rag$": "<rootDir>/packages/rag/src/index.ts",
      "^@fountem/detection$": "<rootDir>/packages/detection/src/index.ts",
      "^@fountem/ui$": "<rootDir>/packages/ui/src/index.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "strict": false,
          "esModuleInterop": true,
          "module": "commonjs",
          "moduleResolution": "node"
        }
      }]
    }
  }
}
