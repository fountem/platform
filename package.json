{
  "name": "fountem-platform",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:mock": "MOCK_SERVICES=1 NEXT_PUBLIC_MOCK_SERVICES=1 turbo run dev",
    "build": "turbo run build",
    "lint": "eslint . --max-warnings 0",
    "test": "jest --passWithNoTests",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@eslint/js": "^9.39.4",
    "@supabase/supabase-js": "^2.47.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "openai": "^4.78.1",
    "ts-jest": "^29.2.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/packages/**/__tests__/**/*.test.ts",
      "**/apps/bot/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@fountem/db$": "<rootDir>/packages/db/src/index.ts",
      "^@fountem/verdict$": "<rootDir>/packages/verdict/src/index.ts",
      "^@fountem/rag$": "<rootDir>/packages/rag/src/index.ts",
      "^@fountem/detection$": "<rootDir>/packages/detection/src/index.ts",
      "^@fountem/core$": "<rootDir>/packages/core/src/index.ts",
      "^@fountem/ui$": "<rootDir>/packages/ui/src/index.ts",
      "^@fountem/social$": "<rootDir>/packages/social/src/index.ts"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": false,
            "esModuleInterop": true,
            "module": "commonjs",
            "moduleResolution": "node",
            "jsx": "react-jsx"
          }
        }
      ]
    }
  }
}
